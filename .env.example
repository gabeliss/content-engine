# Convex
VITE_CONVEX_URL=your_convex_deployment_url_here

# OpenAI API (for text generation)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API (for image generation with Nano Banana)
GEMINI_API_KEY=your_gemini_api_key_here

# TikTok API (for OAuth and posting)
# Get these from https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# OAuth redirect URI - must match exactly in TikTok app settings
# Development:
TIKTOK_REDIRECT_URI=http://localhost:5173
# Production (update this when deploying):
# TIKTOK_REDIRECT_URI=https://your-domain.com
